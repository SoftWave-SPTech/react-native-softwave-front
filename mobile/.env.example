# Copie para `.env` na pasta mobile (o Expo não lê só o .example).
#
# API-AUTH-MAIL (login + recuperação de senha): mesma base — /auth/login, /auth/solicitar-reset-senha, /auth/resetar-senha.
# - Celular na mesma rede: http://SEU_IP_LAN:8083 (não use localhost no aparelho físico)
# - Emulador Android: http://10.0.2.2:8083
EXPO_PUBLIC_AUTH_API_URL=http://localhost:8083

# API financeira principal (dashboard, transações, relatórios etc)
# Ex.: backend-mobile em http://SEU_IP_LAN:8080/v1
EXPO_PUBLIC_API_URL=http://localhost:8080/v1

# API IA financeira: base sem /v1 (API-IA-MOBILE roda em 8084 por padrão)
# - Web local: http://localhost:8084
# - Emulador Android: http://10.0.2.2:8084
# - Celular físico: http://SEU_IP_LAN:8084
EXPO_PUBLIC_IA_API_URL=http://localhost:8084